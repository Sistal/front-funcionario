# ============================================
# Variables de Entorno - Front Funcionario
# ============================================

# URL base del servicio de autenticación
VITE_API_AUTH_BASE=http://localhost:8080

# URL base del servicio de funcionario/BFF
VITE_API_FUNCIONARIO_BASE=http://localhost:8081

# URL de la página de login
VITE_LOGIN_URL=http://localhost:5174

# Habilitar modo mock (true/false)
# En desarrollo local, use 'true' para usar datos mockeados
# En producción, use 'false' para conectar a APIs reales
VITE_USE_MOCK=true
